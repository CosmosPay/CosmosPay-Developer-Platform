{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:sdk": "node scripts/generate-sdk.mjs",
    "generate:api": "node scripts/generate-api.mjs",
    "sync:ui": "node scripts/sync-portal-ui.mjs",
    "generate": "npm run generate:sdk && npm run generate:api && npm run sync:ui",
    "predev": "npm run generate",
    "dev": "next dev",
    "prebuild": "npm run generate",
    "build": "next build",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "better-auth": "^1.6.22",
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-openapi": "^11.0.5",
    "fumadocs-ui": "16.10.5",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
