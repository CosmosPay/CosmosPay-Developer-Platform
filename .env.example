# ──────────────────────────────────────────────────────────────
# Cosmos Pay — Developer Platform
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection used by Prisma (accounts / orgs / profiles — own DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmos_devplatform?schema=public

# ── Auth (Better Auth) ──
BETTER_AUTH_SECRET=supersecret
BETTER_AUTH_URL=http://localhost:4321
# Same value as BETTER_AUTH_URL, exposed to the browser bundle (keep in sync).
# In production set both to the public domain, e.g. https://dev.cosmospay.lat
PUBLIC_BETTER_AUTH_URL=http://localhost:4321

# ── Authentik OAuth2 (external login provider) ──
AUTHENTIK_CLIENT_ID=your-authentik-client-id
AUTHENTIK_CLIENT_SECRET=your-authentik-client-secret
AUTHENTIK_DISCOVERY_URL=http://localhost:9000/application/o/cosmos/.well-known/openid-configuration

# ── APISIX (admin API: provisions consumers / keys / routes) ──
APISIX_URL=http://127.0.0.1:9180/apisix/admin
APISIX_ADMIN_KEY=apikeyofapisix
APISSIX_ROUTE_ID=cosmos-api-keys

# ── Cosmos Payments API (the community server, proxied via APISIX) ──
COSMOS_API_URL=http://localhost:3000
COSMOS_API_ENTRY="/cosmos-api/*"
COSMOS_API_REWRITE=["^/cosmos-api/(.*)","/$1"]
# REQUIRED. Must equal the community server's APISIX_GATEWAY_SECRET (it always enforces it;
# empty → every Payments API call 403s). `openssl rand -hex 32`.
COSMOS_GATEWAY_SECRET=replace-with-a-long-random-secret

# ── Documentation (/docs) ──
# The /docs content (content/docs/{sdk,api} + openapi.json) is GENERATED from the external SDK +
# community-server repos but COMMITTED to this repo, so the build never needs those repos: on a
# box without them, generate-sdk/generate-api skip and the build uses the committed content.
# To refresh the docs, build locally where the repos are (`npm run build`) and commit the updated
# content/docs/{sdk,api} + docs/openapi.json. Production then just builds from that committed content.
# Optional: override where the generators read their sources (defaults are the sibling repos
# ../cosmosjs_sdk/llms + its dist/*.d.ts, and ../comos-pay-community-server/openapi/openapi.json):
SDK_LLMS_DIR=
OPENAPI_SRC=

# ── Email (organization invitations / magic links) ──
# SMTP transport. SMTP_FROM must be a VERIFIED sender. 465 → SMTP_SECURE=true · 587 → false.
# Alternative: to use the Resend HTTP API (works where SMTP ports are blocked), add
# RESEND_API_KEY instead of the SMTP_* vars — it takes priority when set.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
SMTP_FROM=no-reply@your-verified-domain.com

# ── Feature flags (plans & onboarding) ──
ONBOARDING_ENABLED=true
PLANS_ENABLED=true
ALLOW_USER_PLAN_CHANGES=true
ENABLED_PLANS=

# ── API reference (Swagger) ──
# Exposes the portal's own API reference (Swagger UI at /swagger + the /api/openapi.json spec).
# It's a developer/internal tool: ON automatically in development, OFF in production. Set true to
# also expose it in a specific environment (e.g. staging). Leave empty/false for production.
API_DOCS_ENABLED=false

# ── Analytics ──
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Empty = tracking disabled.
# PUBLIC_ vars are embedded at build time → rebuild after changing this.
PUBLIC_GA_ID=

# ── SEO / Google Search Console ──
# Ownership-verification token. In Search Console pick "HTML tag" and paste ONLY the
# value inside content="…" here (not the whole tag). When set, the verification
# <meta> is rendered on every public page. Empty = no tag. Rebuild after changing
# (PUBLIC_ vars are embedded at build time). Search Console can also verify via the
# PUBLIC_GA_ID property above, or by the /sitemap.xml + /robots.txt already shipped.
PUBLIC_GOOGLE_SITE_VERIFICATION=
