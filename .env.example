# PostgreSQL connection used by Prisma (own accounts/profile system)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosmos_devplatform?schema=public

BETTER_AUTH_SECRET=supersecret
BETTER_AUTH_URL=http://localhost:4321
# Same value as BETTER_AUTH_URL, exposed to the browser for the auth client.
# In production set both to the public domain, e.g. https://dev.cosmospay.lat
PUBLIC_BETTER_AUTH_URL=http://localhost:4321

# Authentik OAuth2 (the external login provider)
AUTHENTIK_CLIENT_ID=your-authentik-client-id
AUTHENTIK_CLIENT_SECRET=your-authentik-client-secret
AUTHENTIK_DISCOVERY_URL=http://localhost:9000/application/o/cosmos/.well-known/openid-configuration

APISIX_URL=http://127.0.0.1:9180/apisix/admin
APISIX_ADMIN_KEY=apikeyofapisix
APISSIX_ROUTE_ID=cosmos-api-keys

# Upstream the APISIX route proxies to — set this to the real Cosmos API backend.
# (The APISIX route is (re)synced to this value every time the app starts.)
COSMOS_API_URL=http://localhost:3000
COSMOS_API_ENTRY="/cosmos-api/*" # The entry point of the cosmos API
# The rewrite path of the cosmos API
COSMOS_API_REWRITE=["^/cosmos-api/(.*)","/$1"]
# Shared gateway secret of the Cosmos Payments API (its APISIX_GATEWAY_SECRET).
# The dashboard calls the Payments API directly (server-to-server) and presents this
# secret + the consumer identity, exactly as APISIX would. Leave empty when the
# upstream runs with ENFORCE_GATEWAY=false (local dev).
COSMOS_GATEWAY_SECRET=

# --- SMTP (organization invitation emails / magic links) ---
# Set these to enable sending invitations. When unset, the invite API returns a clear
# "email isn't configured" error and no email is sent.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com

# --- Feature flags (plans & onboarding) ---
# Run the multi-step onboarding wizard. false → auto-provision a default org and go
# straight to the dashboard.
ONBOARDING_ENABLED=true
# Master switch for plan features. false → all plan UI hidden, everyone on the default plan.
PLANS_ENABLED=true
# Allow regular users to change their own plan. false → only owner/admin accounts can.
ALLOW_USER_PLAN_CHANGES=true
# Comma-separated plan ids offered for self-selection (first = default). Empty = all.
# e.g. "community" to only allow community-plan registration.
ENABLED_PLANS=