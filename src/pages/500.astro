---
// Custom Server Error page — Astro serves this when a page render throws (replacing its default).
// `Astro.props.error` is available here; we log it but never surface details to the visitor.
import ErrorPage from "@/components/ErrorPage.astro";

const { error } = Astro.props;
if (error) console.error("[500]", error instanceof Error ? error.stack : error);

Astro.response.status = 500;
---

<ErrorPage
  code="500"
  title="Something went wrong"
  message="An unexpected error occurred on our side. Please try again in a moment — if it keeps happening, contact support."
/>
