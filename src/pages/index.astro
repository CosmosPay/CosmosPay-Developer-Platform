---
import CosmosLayout from "@/layouts/CosmosLayout.astro";
import Landing from "@/components/cosmos/Landing.tsx";

const lang = Astro.cookies.get("cosmospay-lang")?.value ?? "en";
const user = Astro.locals.user
  ? { name: Astro.locals.user.name, email: Astro.locals.user.email, image: Astro.locals.user.image }
  : null;
---

<CosmosLayout
  title="Cosmos Pay — Developer Platform for Stellar Payments"
  description="Issue API keys and integrate Stellar (SEP-7) payments with Cosmos Pay: create payment intents, manage webhooks, products and customers, and track analytics — all from one developer dashboard."
  lang={lang}
>
  <Landing client:load user={user} lang={lang} />
</CosmosLayout>
