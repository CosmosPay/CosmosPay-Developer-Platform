---
// Custom Not Found page — Astro serves this for any unmatched route (replacing its default).
import ErrorPage from "@/components/ErrorPage.astro";

Astro.response.status = 404;
---

<ErrorPage
  code="404"
  title="Page not found"
  message="The page you're looking for doesn't exist or may have moved. Check the URL, or head back and try again."
/>
