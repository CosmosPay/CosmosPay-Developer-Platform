---
import { PUBLIC_GA_ID, PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
export const prerender = false;

const description =
  "Interactive API reference for the Cosmos Pay Payments API: Stellar SEP-7 payment intents, webhooks, products, customers and analytics (OpenAPI).";
const canonical = new URL("/docs", Astro.site ?? "https://dev.cosmospay.lat").href;
const gaId = PUBLIC_GA_ID;
const googleSiteVerification = PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>API Reference — Cosmos Pay</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cosmos Pay" />
    <meta property="og:title" content="API Reference — Cosmos Pay" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/og-image.png", Astro.site ?? "https://dev.cosmospay.lat").href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/swagger-ui-dist@5.21.0/swagger-ui.css"
    />
    <style>
      body {
        margin: 0;
        background: #fafafa;
      }
    </style>
    {gaId && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script
          is:inline
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`}
        />
      </Fragment>
    )}
  </head>
  <body>
    <div id="swagger-ui"></div>
    <script
      is:inline
      src="https://unpkg.com/swagger-ui-dist@5.21.0/swagger-ui-bundle.js"
    ></script>
    <script
      is:inline
      src="https://unpkg.com/swagger-ui-dist@5.21.0/swagger-ui-standalone-preset.js"
    ></script>
    <script is:inline>
      window.onload = function () {
        window.ui = SwaggerUIBundle({
          url: '/api/openapi.json',
          dom_id: '#swagger-ui',
          deepLinking: true,
          presets: [
            SwaggerUIBundle.presets.apis,
            SwaggerUIStandalonePreset,
          ],
          layout: 'StandaloneLayout',
          persistAuthorization: true,
        });
      };
    </script>
  </body>
</html>
