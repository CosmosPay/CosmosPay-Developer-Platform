{
  "name": "paydev",
  "type": "module",
  "version": "0.1.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "prisma migrate deploy && node scripts/ensure-docs.mjs",
    "dev": "astro dev --host",
    "build": "prisma generate && npm run docs:build && astro build",
    "docs:build": "node scripts/build-docs.mjs",
    "prestart": "node scripts/ensure-docs.mjs",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "sync:route": "node scripts/sync-apisix-route.mjs"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.7",
    "axios": "^1.18.1",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "gsap": "^3.15.0",
    "maxmind": "^5.0.6",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@hono/node-server": "^1.19.14"
  }
