    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.1",
    "axios": "^1.17.0",
    "better-auth": "^1.6.10",
    "dotenv": "^16.4.7",
    "gsap": "^3.15.0",
    "maxmind": "^5.0.6",
    "nodemailer": "^9.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
